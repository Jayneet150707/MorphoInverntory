@model IEnumerable<MorphoInventoryUI.Models.DeviceOrderRequest>

@{
    ViewData["Title"] = "Orders";
    var statusFilter = ViewBag.StatusFilter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        @if (!string.IsNullOrEmpty(statusFilter))
        {
            <span>@statusFilter Orders</span>
        }
        else
        {
            <span>All Orders</span>
        }
    </h1>
    <div>
        <a asp-action="Create" class="btn btn-primary">Create New Order</a>
    </div>
</div>

<div class="mb-4">
    <div class="btn-group" role="group">
        <a asp-action="Index" class="btn @(string.IsNullOrEmpty(statusFilter) ? "btn-primary" : "btn-outline-primary")">All</a>
        <a asp-action="Pending" class="btn @(statusFilter == "Pending" ? "btn-primary" : "btn-outline-primary")">Pending</a>
        <a asp-action="Approved" class="btn @(statusFilter == "Approved" ? "btn-primary" : "btn-outline-primary")">Approved</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No orders found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Id)</th>
                    <th>@Html.DisplayNameFor(model => model.Creator)</th>
                    <th>@Html.DisplayNameFor(model => model.Branch)</th>
                    <th>@Html.DisplayNameFor(model => model.DeviceCount)</th>
                    <th>@Html.DisplayNameFor(model => model.RequestDate)</th>
                    <th>@Html.DisplayNameFor(model => model.Status)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Id)</td>
                        <td>@Html.DisplayFor(modelItem => item.Creator)</td>
                        <td>@Html.DisplayFor(modelItem => item.Branch)</td>
                        <td>@Html.DisplayFor(modelItem => item.DeviceCount)</td>
                        <td>@Html.DisplayFor(modelItem => item.RequestDate)</td>
                        <td>
                            <span class="badge @(item.Status == "Approved" ? "bg-success" : item.Status == "Pending" ? "bg-warning text-dark" : item.Status == "Rejected" ? "bg-danger" : "bg-secondary")">
                                @Html.DisplayFor(modelItem => item.Status)
                            </span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                @if (item.Status == "Pending")
                                {
                                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                                }
                                @if (item.Status != "Rejected" && item.Status != "Completed")
                                {
                                    <a asp-action="UpdateStatus" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Update Status</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

