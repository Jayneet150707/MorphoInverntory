@model IEnumerable<MorphoInventoryUI.Models.DeviceAssignment>

@{
    ViewData["Title"] = "Assignments";
    var assigneeFilter = ViewBag.AssigneeFilter as string;
    var branchFilter = ViewBag.BranchFilter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        @if (!string.IsNullOrEmpty(assigneeFilter))
        {
            <span>Assignments to @assigneeFilter</span>
        }
        else if (!string.IsNullOrEmpty(branchFilter))
        {
            <span>Assignments to @branchFilter</span>
        }
        else
        {
            <span>All Assignments</span>
        }
    </h1>
    <div>
        <a asp-action="AssignToCoordinator" class="btn btn-primary me-2">Assign to Coordinator</a>
        <a asp-action="AssignToBranch" class="btn btn-success">Assign to Branch</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No assignments found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.SerialNumber)</th>
                    <th>@Html.DisplayNameFor(model => model.Company)</th>
                    <th>@Html.DisplayNameFor(model => model.DeviceType)</th>
                    <th>@Html.DisplayNameFor(model => model.AssignedTo)</th>
                    <th>@Html.DisplayNameFor(model => model.Branch)</th>
                    <th>@Html.DisplayNameFor(model => model.CsoId)</th>
                    <th>@Html.DisplayNameFor(model => model.AssignmentDate)</th>
                    <th>@Html.DisplayNameFor(model => model.Status)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.SerialNumber)</td>
                        <td>@Html.DisplayFor(modelItem => item.Company)</td>
                        <td>@Html.DisplayFor(modelItem => item.DeviceType)</td>
                        <td>@Html.DisplayFor(modelItem => item.AssignedTo)</td>
                        <td>@Html.DisplayFor(modelItem => item.Branch)</td>
                        <td>@Html.DisplayFor(modelItem => item.CsoId)</td>
                        <td>@Html.DisplayFor(modelItem => item.AssignmentDate)</td>
                        <td>
                            <span class="badge @(item.Status == "Active" ? "bg-success" : "bg-secondary")">
                                @Html.DisplayFor(modelItem => item.Status)
                            </span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                @if (item.Status == "Active" && string.IsNullOrEmpty(item.Branch))
                                {
                                    <a asp-action="AssignToBranch" asp-route-serialNumber="@item.SerialNumber" class="btn btn-sm btn-success">Assign to Branch</a>
                                }
                                @if (item.Status == "Active" && !string.IsNullOrEmpty(item.Branch))
                                {
                                    <a asp-controller="Return" asp-action="Create" asp-route-serialNumber="@item.SerialNumber" class="btn btn-sm btn-warning">Return</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

