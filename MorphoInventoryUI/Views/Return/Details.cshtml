@model MorphoInventoryUI.Models.DeviceReturnRequest

@{
    ViewData["Title"] = "Return Request Details";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Return Request Details</h4>
                <span class="badge @(Model.Status == "Accepted" ? "bg-success" : "bg-warning text-dark")">
                    @Html.DisplayFor(model => model.Status)
                </span>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.SerialNumber)</div>
                    <div class="col-md-8">@Html.DisplayFor(model => model.SerialNumber)</div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.CsoId)</div>
                    <div class="col-md-8">@Html.DisplayFor(model => model.CsoId)</div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.IssueType)</div>
                    <div class="col-md-8">@Html.DisplayFor(model => model.IssueType)</div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.Remarks)</div>
                    <div class="col-md-8">@Html.DisplayFor(model => model.Remarks)</div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.RequestDate)</div>
                    <div class="col-md-8">@Html.DisplayFor(model => model.RequestDate)</div>
                </div>
                
                @if (Model.Status == "Accepted")
                {
                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.AcceptanceRemarks)</div>
                        <div class="col-md-8">@Html.DisplayFor(model => model.AcceptanceRemarks)</div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.AcceptanceDate)</div>
                        <div class="col-md-8">@Html.DisplayFor(model => model.AcceptanceDate)</div>
                    </div>
                }
                
                <div class="row mb-3">
                    <div class="col-md-4 fw-bold">@Html.DisplayNameFor(model => model.DeviceImage)</div>
                    <div class="col-md-8">
                        <img src="data:image/jpeg;base64,@Model.DeviceImage" alt="Device Image" class="img-fluid img-thumbnail" style="max-height: 300px;" />
                    </div>
                </div>
                
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    
                    @if (Model.Status == "Pending")
                    {
                        <a asp-action="Accept" asp-route-id="@Model.Id" class="btn btn-success">Accept Return</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

