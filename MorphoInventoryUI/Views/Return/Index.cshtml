@model IEnumerable<MorphoInventoryUI.Models.DeviceReturnRequest>

@{
    ViewData["Title"] = "Return Requests";
    var statusFilter = ViewBag.StatusFilter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        @if (!string.IsNullOrEmpty(statusFilter))
        {
            <span>@statusFilter Return Requests</span>
        }
        else
        {
            <span>All Return Requests</span>
        }
    </h1>
    <div>
        <a asp-action="Create" class="btn btn-primary">Create Return Request</a>
    </div>
</div>

<div class="mb-4">
    <div class="btn-group" role="group">
        <a asp-action="Index" class="btn @(string.IsNullOrEmpty(statusFilter) ? "btn-primary" : "btn-outline-primary")">All</a>
        <a asp-action="Pending" class="btn @(statusFilter == "Pending" ? "btn-primary" : "btn-outline-primary")">Pending</a>
        <a asp-action="Accepted" class="btn @(statusFilter == "Accepted" ? "btn-primary" : "btn-outline-primary")">Accepted</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No return requests found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.SerialNumber)</th>
                    <th>@Html.DisplayNameFor(model => model.CsoId)</th>
                    <th>@Html.DisplayNameFor(model => model.IssueType)</th>
                    <th>@Html.DisplayNameFor(model => model.RequestDate)</th>
                    <th>@Html.DisplayNameFor(model => model.Status)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.SerialNumber)</td>
                        <td>@Html.DisplayFor(modelItem => item.CsoId)</td>
                        <td>@Html.DisplayFor(modelItem => item.IssueType)</td>
                        <td>@Html.DisplayFor(modelItem => item.RequestDate)</td>
                        <td>
                            <span class="badge @(item.Status == "Accepted" ? "bg-success" : "bg-warning text-dark")">
                                @Html.DisplayFor(modelItem => item.Status)
                            </span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                @if (item.Status == "Pending")
                                {
                                    <a asp-action="Accept" asp-route-id="@item.Id" class="btn btn-sm btn-success">Accept</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

